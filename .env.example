# Porta do servidor
PORT=3000

# Segredo usado para assinar os tokens JWT de autenticação (obrigatório)
JWT_SECRET=troque-por-um-valor-aleatorio-longo

# Token do webhook configurado no painel da Greenn (Integração e Tokens)
GREENN_WEBHOOK_TOKEN=troque-pelo-token-da-greenn

# URL pública onde o site está publicado (usada para montar o link de ativação
# enviado por e-mail para novas compradoras, e o link de checkout do botão).
APP_URL=http://localhost:3000

# Chave de API da Resend (resend.com), usada para enviar o e-mail de ativação
# de conta após a compra na Greenn. Sem essa chave, o e-mail simplesmente não
# é enviado (fica registrado um aviso no log). Pode reusar a mesma conta/domínio
# já verificado para o pietra (blindadokp.com.br).
RESEND_API_KEY=

# Remetente do e-mail de ativação.
EMAIL_FROM=BlindadoKP <onboarding@resend.dev>

# Caminho do arquivo do banco SQLite (opcional, padrão: data/app.db)
# DATABASE_PATH=./data/app.db

# Credenciais opcionais para criar um usuário admin ao rodar `npm run seed`
# SEED_ADMIN_EMAIL=admin@blindadokp.com.br
# SEED_ADMIN_PASSWORD=troque-por-uma-senha-forte
